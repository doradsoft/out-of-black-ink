{
  "name": "@doradsoft/out-of-black-ink-web",
  "private": true,
  "version": "0.1.0",
  "description": "Client-side web app for recoloring black and gray PDF content.",
  "license": "MIT",
  "author": "Dorad Soft",
  "type": "module",
  "homepage": "https://doradsoft.github.io/out-of-black-ink/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doradsoft/out-of-black-ink.git",
    "directory": "apps/web"
  },
  "bugs": {
    "url": "https://github.com/doradsoft/out-of-black-ink/issues"
  },
  "scripts": {
    "build": "vite build",
    "check": "npm run prepare:core && npm run lint && npm run typecheck && npm run format:check && npm run build",
    "dev": "vite --host 127.0.0.1",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "prepare:core": "npm run build --workspace @doradsoft/out-of-black-ink",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@doradsoft/out-of-black-ink": "file:../../packages/typescript",
    "jspdf": "4.2.1",
    "pdfjs-dist": "5.7.284"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.8.0",
    "eslint": "10.4.0",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vite": "8.0.13"
  }
}
